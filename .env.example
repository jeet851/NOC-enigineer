# ============================================================
# Zero-Trust AI NOC Copilot — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ────────────────────────────────────────────────────────────
# APPLICATION ENVIRONMENT
# ────────────────────────────────────────────────────────────
# Options: development | testing | production
APP_ENV=development

# Enable debug mode (NEVER True in production)
DEBUG=False

# ────────────────────────────────────────────────────────────
# SERVER BINDING
# ────────────────────────────────────────────────────────────
# 127.0.0.1 = localhost only (secure default)
# 0.0.0.0   = expose to network (development only)
BIND_HOST=127.0.0.1
PORT=5001

# ────────────────────────────────────────────────────────────
# DATABASE
# ────────────────────────────────────────────────────────────
# SQLite (development/testing — auto-created, no setup needed)
DATABASE_URL=sqlite:///./noc_local.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/noc_db

# Connection pool (PostgreSQL only)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ────────────────────────────────────────────────────────────
# REDIS
# ────────────────────────────────────────────────────────────
# Redis is optional — the platform falls back to in-memory if unavailable
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_SOCKET_TIMEOUT=0.5
REDIS_CONNECT_TIMEOUT=0.5
REDIS_KEY_PREFIX=NOC:
REDIS_CACHE_TTL_SECONDS=3
REDIS_CHALLENGE_TTL_SECONDS=300

# ────────────────────────────────────────────────────────────
# RABBITMQ / CELERY (for async task workers)
# ────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672//

# ────────────────────────────────────────────────────────────
# SECURITY — JWT
# ────────────────────────────────────────────────────────────
# REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ────────────────────────────────────────────────────────────
# RATE LIMITING
# ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10

# ────────────────────────────────────────────────────────────
# LOGGING
# ────────────────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=noc_copilot.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# ────────────────────────────────────────────────────────────
# SSL / TLS
# ────────────────────────────────────────────────────────────
# If cert files exist at these paths, HTTPS is enabled automatically.
# If not found, the server falls back to HTTP (development only).
SSL_CERT_PATH=localhost.crt
SSL_KEY_PATH=localhost.key

# ────────────────────────────────────────────────────────────
# SLACK INTEGRATION
# ────────────────────────────────────────────────────────────
# Get Bot Token from: Settings → OAuth & Permissions (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Get App Token from: Settings → Basic Information → App-Level Tokens (starts with xapp-)
# Scope required: connections:write
SLACK_APP_TOKEN=xapp-your-slack-app-token

# ────────────────────────────────────────────────────────────
# GOOGLE GEMINI AI
# ────────────────────────────────────────────────────────────
# Optional. If not set, AI falls back to high-fidelity template responses.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_SECONDS=30

# ────────────────────────────────────────────────────────────
# TELEMETRY
# ────────────────────────────────────────────────────────────
TELEMETRY_INTERVAL_SECONDS=5
TELEMETRY_RETENTION_DAYS=30

# ────────────────────────────────────────────────────────────
# AUTOMATION / DEVICE SSH
# ────────────────────────────────────────────────────────────
# FORCE_SIMULATION=True means the platform uses simulated CLI responses
# instead of live SSH. Set to False only with real device credentials.
FORCE_SIMULATION=True
SSH_TIMEOUT_SECONDS=10

# ────────────────────────────────────────────────────────────
# NEO4J TOPOLOGY GRAPH (optional)
# ────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ────────────────────────────────────────────────────────────
# ALARM THRESHOLDS
# ────────────────────────────────────────────────────────────
ALARM_CPU_THRESHOLD=90
ALARM_RAM_THRESHOLD=90
ALARM_DISK_THRESHOLD=90
ALARM_PACKET_LOSS_THRESHOLD=5.0
ALARM_RTT_THRESHOLD=200.0
ALARM_TEMP_THRESHOLD=75

# ────────────────────────────────────────────────────────────
# AI INCIDENT ENGINE
# ────────────────────────────────────────────────────────────
# Confidence % above which the AI will autonomously apply fixes
AI_CONFIDENCE_AUTONOMOUS_THRESHOLD=95.0
