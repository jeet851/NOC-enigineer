# Slack API Credentials
# Get Bot Token from Settings -> OAuth & Permissions (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Get App Token from Settings -> Basic Information -> App-Level Tokens (starts with xapp-)
# Make sure to grant connections:write scope to the App Token
SLACK_APP_TOKEN=xapp-your-slack-app-token

# Optional: Google Gemini API Key
# If provided, responses will be generated using Gemini. Otherwise, responses will be simulated.
GEMINI_API_KEY=your-gemini-api-key

# Server Network & Security Configurations
# BIND_HOST restricts server access. Defaults to 127.0.0.1 (Secure Localhost).
# Change to 0.0.0.0 to expose the server to your local network.
BIND_HOST=127.0.0.1
PORT=5001

# SSL certificate and private key paths.
# If files do not exist at these paths, a self-signed localhost certificate will be generated automatically.
SSL_CERT_PATH=localhost.crt
SSL_KEY_PATH=localhost.key

# Database, Redis, and MQ Settings
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/noc_db
REDIS_URL=redis://127.0.0.1:6379/0
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672//

# Security Configs
JWT_SECRET_KEY=your-super-secret-jwt-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

